{
  "name": "@safe-git/commit-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "safegit": "bin/safegit.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@safe-git/core": "workspace:*",
    "@safe-git/signer-node": "workspace:*",
    "@safe-git/verifier": "workspace:*"
  }
}
